# Port the API + Socket.IO server listens on
PORT=4000

# MongoDB Atlas connection string (see README "1. MongoDB Atlas" section)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tempmail?retryWrites=true&w=majority

# Comma-separated list of domains this server accepts mail for.
# Must match the domains you onboard in Cloudflare Email Routing.
DOMAINS=tempmail1.com,tempmail2.com

# Shared secret the Cloudflare Email Worker must send in the
# "x-webhook-secret" header when it POSTs an inbound email to /api/inbound.
# Generate a long random string, e.g.: openssl rand -hex 32
WEBHOOK_SECRET=change-this-to-a-long-random-string

# How long (in seconds) an email is kept before MongoDB auto-deletes it (TTL index).
# 86400 = 24 hours.
MAIL_TTL_SECONDS=86400

# Comma-separated list of allowed frontend origins for CORS + Socket.IO.
# Use * only for quick local testing.
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
